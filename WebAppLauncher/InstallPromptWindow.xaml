<Window x:Class="WebAppLauncher.InstallPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WebAppLauncher · 설치"
        Height="280"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#F7F8F8">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="WebApp 설치"
                       FontSize="12"
                       Foreground="#5C6B6B"
                       Margin="0,0,0,12"/>
            <TextBlock x:Name="AppNameText"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#1F2A2A"
                       TextWrapping="Wrap"
                       Text="불러오는 중..."/>
            <TextBlock x:Name="AppNameSuffixText"
                       FontSize="14"
                       Foreground="#1F2A2A"
                       Margin="0,4,0,0"
                       Text="을(를) 설치하시겠습니까?"/>
            <TextBlock x:Name="MetaText"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#3F4F4F"
                       Margin="0,18,0,0"
                       TextWrapping="Wrap"
                       Text=""/>
            <TextBlock x:Name="StatusText"
                       FontSize="12"
                       Foreground="#5C6B6B"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Content="취소"
                    Width="96"
                    Height="32"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
            <Button x:Name="InstallButton"
                    Content="설치"
                    Width="96"
                    Height="32"
                    IsDefault="True"
                    Click="InstallButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
